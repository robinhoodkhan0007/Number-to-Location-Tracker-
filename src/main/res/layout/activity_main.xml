<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#E3F2FD">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📱 Number Tracker 📱"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:gravity="center"
        android:layout_marginBottom="30dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="15dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="নম্বর দিয়ে খুঁজুন"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/inputNumber"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="01700000000"
            android:inputType="phone"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:textColor="#333"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/searchNumberBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔍 খুঁজুন"
            android:textSize="16sp"
            android:background="#2196F3"
            android:textColor="#fff" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="15dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IMEI দিয়ে খুঁজুন"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/inputIMEI"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="353658052037312"
            android:inputType="number"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:textColor="#333"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/searchIMEIBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📞 খুঁজুন"
            android:textSize="16sp"
            android:background="#4CAF50"
            android:textColor="#fff" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ফলাফল"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="এখানে ফলাফল দেখাবে"
            android:textSize="14sp"
            android:textColor="#666"
            android:padding="10dp" />
    </LinearLayout>
</LinearLayout>
